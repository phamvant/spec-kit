{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "sprint"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "sprint": {
      "type": "object",
      "required": ["id", "plan_id", "title", "goal", "status", "requirements", "features", "depends_on", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^SPRINT-[0-9]{3,}$"},
        "plan_id": {"type": "string", "pattern": "^AGILE-PLAN-[0-9]{3,}$"},
        "title": {"type": "string", "minLength": 1},
        "goal": {"type": "string", "minLength": 1},
        "status": {"enum": ["planned", "in_progress", "blocked", "implemented", "verified"]},
        "requirements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"}
        },
        "features": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title", "required", "requirements", "status", "tasks", "verification"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "pattern": "^[0-9]{3,}-[a-z0-9][a-z0-9-]*$"},
              "title": {"type": "string", "minLength": 1},
              "required": {"type": "boolean"},
              "requirements": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"}
              },
              "status": {"enum": ["planned", "in_progress", "implemented", "verified"]},
              "tasks": {
                "type": "object",
                "required": ["total", "completed", "incomplete"],
                "additionalProperties": false,
                "properties": {
                  "total": {"type": "integer", "minimum": 0},
                  "completed": {"type": "integer", "minimum": 0},
                  "incomplete": {"type": "integer", "minimum": 0}
                }
              },
              "verification": {
                "type": "object",
                "required": ["status"],
                "additionalProperties": false,
                "properties": {
                  "status": {"enum": ["not-run", "failed", "passed"]}
                }
              }
            }
          }
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^SPRINT-[0-9]{3,}$"}
        },
        "updated_at": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "format": "date-time"}
          ]
        }
      }
    }
  }
}
