{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "product",
    "scope",
    "candidates",
    "open_questions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "product": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "scope": {
      "type": "object",
      "required": ["included", "excluded"],
      "additionalProperties": false,
      "properties": {
        "included": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "excluded": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidate"}
    },
    "open_questions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "capability_token",
        "title",
        "description",
        "type",
        "capability",
        "priority",
        "owner",
        "source",
        "verification",
        "evidence",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^CAND-[0-9]{3,}$"
        },
        "capability_token": {
          "type": "string",
          "pattern": "^[A-Z0-9]+$"
        },
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "type": {
          "enum": ["goal", "capability", "functional", "quality", "constraint"]
        },
        "capability": {"type": "string", "minLength": 1},
        "priority": {"enum": ["must", "should", "could", "wont"]},
        "owner": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "verification": {
          "type": "object",
          "required": ["method"],
          "additionalProperties": false,
          "properties": {
            "method": {"type": "string", "minLength": 1}
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "reason"],
            "additionalProperties": false,
            "properties": {
              "path": {"type": "string", "minLength": 1},
              "lines": {"type": "string", "minLength": 1},
              "reason": {"type": "string", "minLength": 1}
            }
          }
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
