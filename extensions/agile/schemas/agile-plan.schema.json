{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "plan", "sprints"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "plan": {
      "type": "object",
      "required": ["id", "title", "status", "source_requirements"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^AGILE-PLAN-[0-9]{3,}$"},
        "title": {"type": "string", "minLength": 1},
        "status": {"enum": ["draft", "approved"]},
        "source_requirements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"}
        }
      }
    },
    "sprints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "goal", "status", "requirements", "features", "depends_on"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^SPRINT-[0-9]{3,}$"},
          "title": {"type": "string", "minLength": 1},
          "goal": {"type": "string", "minLength": 1},
          "status": {"enum": ["planned", "in_progress", "blocked", "implemented", "verified"]},
          "requirements": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"}
          },
          "features": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "title", "required", "requirements"],
              "additionalProperties": false,
              "properties": {
                "id": {"type": "string", "pattern": "^[0-9]{3,}-[a-z0-9][a-z0-9-]*$"},
                "title": {"type": "string", "minLength": 1},
                "required": {"type": "boolean"},
                "requirements": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"}
                }
              }
            }
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^SPRINT-[0-9]{3,}$"}
          }
        }
      }
    }
  }
}
