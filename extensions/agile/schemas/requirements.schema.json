{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "product", "requirements", "id_sequences"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0"},
    "product": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "requirements": {
      "type": "array",
      "items": {"$ref": "#/$defs/requirement"}
    },
    "id_sequences": {
      "type": "object",
      "propertyNames": {"pattern": "^[A-Z0-9]+$"},
      "additionalProperties": {"type": "integer", "minimum": 0}
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "required": ["id", "title", "description", "type", "capability", "status", "priority", "owner", "source", "verification"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "type": {"enum": ["goal", "capability", "functional", "quality", "constraint"]},
        "capability": {"type": "string", "minLength": 1},
        "status": {"enum": ["proposed", "reviewed", "approved", "implementing", "implemented", "verified", "deprecated", "retired"]},
        "priority": {"enum": ["must", "should", "could", "wont"]},
        "owner": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "verification": {
          "type": "object",
          "required": ["method"],
          "additionalProperties": false,
          "properties": {"method": {"type": "string", "minLength": 1}}
        },
        "depends_on": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"}},
        "supersedes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^PRD-[A-Z0-9]+-[0-9]{3,}$"}},
        "tags": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
